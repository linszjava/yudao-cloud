# 停止继续往父目录查找 lombok.config（到此为止，这是最顶层配置）
config.stopBubbling = true

# @ToString 自动加上 callSuper = true（打印时包含父类字段）
lombok.tostring.callsuper = CALL

# @EqualsAndHashCode 自动加上 callSuper = true（比较时包含父类字段）
lombok.equalsandhashcode.callsuper = CALL

# @Setter 生成的方法返回 this 而不是 void（支持链式调用）
# 例如：new UserDO().setName("张三").setAge(18).setStatus(1)
lombok.accessors.chain = true
